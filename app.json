{
  "expo": {
    "name": "Bíblia Online",
    "slug": "holy-bible",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.jpg",
    "scheme": "holybible",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.jpg",
      "bundleIdentifier": "br.com.stevanini.holybible",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "br.com.stevanini.holybible",
      "adaptiveIcon": {
        "backgroundColor": "#008080",
        "foregroundImage": "./assets/images/icon.jpg"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.jpg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#008080",
          "android": {
            "image": "./assets/images/icon.jpg",
            "imageWidth": 200
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e6463f2f-cd02-44ef-b65c-d0be6f637ba3"
      }
    }
  }
}